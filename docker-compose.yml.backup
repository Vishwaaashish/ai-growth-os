services:

  postgres:
    image: postgres:15
    container_name: infrastructure-postgres
    restart: always
    environment:
      POSTGRES_USER: odoo
      POSTGRES_PASSWORD: odoo
      POSTGRES_DB: postgres
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"

  redis:
    image: redis:7
    container_name: infrastructure-redis
    restart: always
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    ports:
      - "6379:6379"

  odoo:
    image: odoo:17
    container_name: infrastructure-odoo
    restart: always
    depends_on:
      - postgres
      - redis
    ports:
      - "8069:8069"
    environment:
      HOST: postgres
      USER: odoo
      PASSWORD: odoo
    volumes:
      - odoo_data:/var/lib/odoo

  n8n:
    image: n8nio/n8n
    container_name: infrastructure-n8n
    restart: always
    ports:
      - "5678:5678"
    volumes:
      - n8n_data:/home/node/.n8n

  prometheus:
    image: prom/prometheus
    container_name: infrastructure-prometheus
    restart: always
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml
    ports:
      - "9090:9090"

  node-exporter:
    image: prom/node-exporter
    container_name: infrastructure-node-exporter
    restart: always
    ports:
      - "9100:9100"

  grafana:
    image: grafana/grafana
    container_name: infrastructure-grafana
    restart: always
    ports:
      - "3000:3000"
    volumes:
      - grafana_data:/var/lib/grafana

volumes:
  postgres_data:
  redis_data:
  odoo_data:
  n8n_data:
  grafana_data:
