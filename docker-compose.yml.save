services:

  postgres:
    image: postgres:15
    container_name: postgres-db
    restart: always
    environment:
      POSTGRES_USER: odoo
      POSTGRES_PASSWORD: odoo
      POSTGRES_DB: postgres
    volumes:
      - postgres-data:/var/lib/postgresql/data

  odoo:
    image: odoo:17
    container_name: odoo-server
    depends_on:
      - postgres
    ports:
      - "8069:8069"
    restart: always

  n8n:
    image: n8nio/n8n
    container_name: n8n
    ports:
      - "5678:5678"
    volumes:
      - n8n-data:/home/node/.n8n
    restart: always

  metabase:
    image: metabase/metabase
    container_name: metabase
    ports:
      - "3000:3000"
    restart: always

  grafana:
    image: grafana/grafana
    container_name: grafana
    ports:
      - "3001:3000"
    restart: always

  nginx:
    image: nginx
    container_name: gateway
    ports:
      - "80:80"
    restart: always

volumes:
  postgres-data:
  n8n-data:
nginx:
  image: nginx
  container_name: gateway
  ports:
    - "80:80"
  volumes:
    - ./nginx/default.conf:/etc/nginx/conf.d/default.conf
  restart: always
